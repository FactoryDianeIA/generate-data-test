{
  "type": "object",
  "required": ["flow", "file", "columns"],
  "properties": {
    "flow": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    },
    "file": {
      "type": "object",
      "required": ["format", "separator", "header"],
      "properties": {
        "format": { "const": "csv" },
        "separator": { "const": ";" },
        "header": { "const": true }
      }
    },
    "columns": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "required",
          "maxLength",
          "format"
        ],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "maxLength": { "type": ["integer", "null"] },
          "format": { "type": ["string", "null"] }
        }
      }
    }
  }
}